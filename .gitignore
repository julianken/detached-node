# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# screenshots / design artifacts
/*.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# payload media uploads
public/media/

# seed script temp files
scripts/.tmp-seed-images/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/tests/.auth/

# Tool configs
.claude/hooks/
.playwright-mcp/
.serena/

# Working directories (drafts, analysis, brainstorming)
# analysis-funnel default ARTIFACT_ROOT — keep out of version control
/analysis-output/
/blog-ideas/
/creative-output/
/launch-plan/
/docs/brainstorms/

# Transient workspaces
tmp/
